{
  "name": "flow-team-skill",
  "version": "0.4.1",
  "description": "Agent skill package for the Flow (flow.team) Open API — read, act, and proactively suggest across projects, tasks, calendar, members, search, and alarms.",
  "type": "module",
  "license": "MIT",
  "author": "Mrbaeksang",
  "homepage": "https://github.com/Mrbaeksang/flow-team-skill#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mrbaeksang/flow-team-skill.git"
  },
  "bugs": {
    "url": "https://github.com/Mrbaeksang/flow-team-skill/issues"
  },
  "keywords": [
    "flow",
    "flow.team",
    "agent-skill",
    "claude",
    "claude-code",
    "openapi",
    "ai-agent",
    "madrascheck"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "flow-team": "skills/flow-team/scripts/flow.mjs"
  },
  "scripts": {
    "setup": "node setup.mjs",
    "check": "node check.mjs",
    "me": "node skills/flow-team/scripts/flow.mjs me",
    "brief": "node skills/flow-team/scripts/brief.mjs",
    "report": "node skills/flow-team/scripts/report.mjs",
    "recommend": "node skills/flow-team/scripts/recommend.mjs",
    "profile": "node skills/flow-team/scripts/profile.mjs",
    "schedule:setup": "node skills/flow-team/scripts/schedule-setup.mjs"
  },
  "files": [
    "skills",
    "setup.mjs",
    "check.mjs",
    "README.md",
    "LICENSE",
    ".env.example"
  ]
}
